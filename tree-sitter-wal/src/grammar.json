{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "wal",
  "word": "base_symbol",
  "rules": {
    "program": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "sexpr"
      }
    },
    "sexpr": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "SYMBOL",
          "name": "list"
        },
        {
          "type": "SYMBOL",
          "name": "quoted"
        },
        {
          "type": "SYMBOL",
          "name": "quasiquoted"
        },
        {
          "type": "SYMBOL",
          "name": "unquote"
        },
        {
          "type": "SYMBOL",
          "name": "unquote_splice"
        },
        {
          "type": "SYMBOL",
          "name": "timed_atom"
        }
      ]
    },
    "timed_atom": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "atom"
        },
        {
          "type": "STRING",
          "value": "@"
        },
        {
          "type": "SYMBOL",
          "name": "atom"
        }
      ]
    },
    "quoted": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "SYMBOL",
          "name": "sexpr"
        }
      ]
    },
    "quasiquoted": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "SYMBOL",
          "name": "sexpr"
        }
      ]
    },
    "unquote": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ","
        },
        {
          "type": "SYMBOL",
          "name": "sexpr"
        }
      ]
    },
    "unquote_splice": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": ",@"
        },
        {
          "type": "SYMBOL",
          "name": "sexpr"
        }
      ]
    },
    "whitespace": {
      "type": "PATTERN",
      "value": "[\\t \\r\\n]+"
    },
    "_comment": {
      "type": "PATTERN",
      "value": ";;.*"
    },
    "atom": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "bool"
        },
        {
          "type": "SYMBOL",
          "name": "operator"
        },
        {
          "type": "SYMBOL",
          "name": "symbol"
        },
        {
          "type": "SYMBOL",
          "name": "float"
        },
        {
          "type": "SYMBOL",
          "name": "int"
        }
      ]
    },
    "int": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "dec_int"
        },
        {
          "type": "SYMBOL",
          "name": "bin_int"
        },
        {
          "type": "SYMBOL",
          "name": "hex_int"
        }
      ]
    },
    "float": {
      "type": "PATTERN",
      "value": "[+-]?[0-9]+\\.[0-9]+"
    },
    "dec_int": {
      "type": "PATTERN",
      "value": "[+-]?[0-9]+"
    },
    "bin_int": {
      "type": "PATTERN",
      "value": "0b[0-1]+"
    },
    "hex_int": {
      "type": "PATTERN",
      "value": "0x[0-9a-fA-F]+"
    },
    "bool": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "true"
        },
        {
          "type": "STRING",
          "value": "false"
        },
        {
          "type": "STRING",
          "value": "#t"
        },
        {
          "type": "STRING",
          "value": "#f"
        },
        {
          "type": "STRING",
          "value": "nil"
        }
      ]
    },
    "operator": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "+"
        },
        {
          "type": "STRING",
          "value": "-"
        },
        {
          "type": "STRING",
          "value": "*"
        },
        {
          "type": "STRING",
          "value": "/"
        },
        {
          "type": "STRING",
          "value": "&&"
        },
        {
          "type": "STRING",
          "value": "||"
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "STRING",
          "value": "!="
        },
        {
          "type": "STRING",
          "value": ">"
        },
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "STRING",
          "value": ">="
        },
        {
          "type": "STRING",
          "value": "<="
        },
        {
          "type": "STRING",
          "value": "!"
        },
        {
          "type": "STRING",
          "value": "**"
        }
      ]
    },
    "symbol": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "base_symbol"
        },
        {
          "type": "SYMBOL",
          "name": "scoped_symbol"
        },
        {
          "type": "SYMBOL",
          "name": "grouped_symbol"
        }
      ]
    },
    "scoped_symbol": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "~"
        },
        {
          "type": "SYMBOL",
          "name": "base_symbol"
        }
      ]
    },
    "grouped_symbol": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#"
        },
        {
          "type": "SYMBOL",
          "name": "base_symbol"
        }
      ]
    },
    "base_symbol": {
      "type": "PATTERN",
      "value": "[a-zA-Z_\\.][=$\\*\\/>:\\.\\-_\\?=%§^!\\\\~+<>|,\\w]*"
    },
    "string": {
      "type": "PATTERN",
      "value": "\"[^\"]*\""
    },
    "list": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "("
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "sexpr_list"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": ")"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "["
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "sexpr_list"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "]"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "{"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "sexpr_list"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "}"
            }
          ]
        }
      ]
    },
    "sexpr_list": {
      "type": "REPEAT1",
      "content": {
        "type": "SYMBOL",
        "name": "sexpr"
      }
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "_comment"
    },
    {
      "type": "SYMBOL",
      "name": "whitespace"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
